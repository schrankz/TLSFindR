setwd("/users/z/s/zschrank/projects/TLSFindR/development_folder/TLSFindR")
library(devtools)
library(Seurat)
library(dplyr)
library(ggplot2)
devtools::load_all()
obj <- readRDS("/users/z/s/zschrank/projects/Data_Processing/GSE206245/processed_samples/GSM6248649_NPC_ST8_processed.rds")
obj <- run_annotation(obj, reference = "HumanPrimaryCellAtlasData", assay = "SCT")
bestk <- find_optimal_k(obj)
obj <- niche_analysis(obj, optimal_k = bestk, num_neighbors = 30, group_by = "SingleR_label", fov = "slice1")
niche_summary <- summarize_niches(obj = obj, cell_label = "SingleR_label", niche_label = "niches", Bcell_label = "B_cell", B_cutoff = 0.2)
obj <- add_niche_metadata(obj, niche_summary)
heatmap <- plot_niche_heatmaps(obj, niche_slot = "niches",  label_slot = 'SingleR_label', normalize_by = "row")
png("/users/z/s/zschrank/projects/TLSFindR/testing/human_NPC_dataset_testing/individual_sample_testing/outputs/ST8_heatmap.png",
width = 2000, height = 1600, res = 300)
ComplexHeatmap::draw(heatmap)
dev.off()
niche_score_plots <- run_niche_scoring(obj, signatures = human_tls_signatures, assay = "SCT", slot = "data", make_plot = TRUE)
ggsave(
filename = "/users/z/s/zschrank/projects/TLSFindR/testing/human_NPC_dataset_testing/individual_sample_testing/outputs/ST8_niche_score_plots.png",
plot = niche_score_plots$plot,
width = 10, height = 7, dpi = 300
)
niche_image <- make_niche_plot(obj, structure_label = "TLS")
