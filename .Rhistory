devtools::load_all()
obj <- readRDS("/users/z/s/zschrank/projects/Data_Processing/GSE206245/processed_samples/GSM6248646_NPC_ST5_processed.rds")
obj <- run_annotation(obj, reference = "HumanPrimaryCellAtlasData", assay = "SCT")
bestk <- find_optimal_k(obj, assay = "SCT", group_by = "SingleR_label")
obj <- niche_analysis(obj, optimal_k = bestk$optimal_k, num_neighbors = 30, group_by = "SingleR_label", fov = "slice1")
library(Seurat)
obj <- niche_analysis(obj, optimal_k = bestk$optimal_k, num_neighbors = 30, group_by = "SingleR_label", fov = "slice1")
niche_summary <- summarize_niches(obj = obj, cell_label = "SingleR_label", niche_label = "niches", Bcell_label = "B_cell", B_cutoff = 0.2, structure_label = "TLS niche", max_subdominant = 1)
obj <- add_niche_metadata(obj, niche_summary)
niche_score_plots <- run_niche_scoring(obj, signatures = human_tls_signatures, assay = "SCT", slot = "data", make_plot = TRUE, palette = ggsci::pal_igv()(length(unique(obj$niches))))
niche_score_plots
